{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GridRunner",
  "version": "2.18.8",
  "identifier": "com.sq756.gridrunner",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GridRunner",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      },
      {
        "label": "auth-gateway",
        "title": "VPN_AUTHENTICATION_GATEWAY",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../gr_agent/main.go"
    ]
  }
}